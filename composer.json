{
    "name": "rtcoder/devdoctor",
    "description": "Developer diagnostics for humans.",
    "keywords": ["diagnostics", "cli", "developer-tools", "env", "docker", "composer", "git"],
    "homepage": "https://github.com/rtcoder/devdoctor",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/rtcoder/devdoctor/issues",
        "source": "https://github.com/rtcoder/devdoctor"
    },
    "authors": [],
    "require": {
        "php": "^8.5",
        "laravel-zero/framework": "^12.0.2",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2",
        "phpacker/phpacker": "^0.6.4"
    },
    "autoload": {
        "psr-4": {
            "DevDoctor\\": "app/",
            "DevDoctor\\Core\\": "app/DevDoctor/Core/",
            "DevDoctor\\Modules\\": "app/DevDoctor/Modules/",
            "DevDoctor\\Commands\\": "app/Commands/",
            "DevDoctor\\Providers\\": "app/Providers/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "devdoctor": {
            "version": "1.38.2"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["devdoctor"]
}
